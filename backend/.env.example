# Copy this file to .env and fill in real credentials
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=serviio_db
MYSQLDUMP_PATH=
MYSQL_PATH=
DB_BACKUP_DIR=

# JWT secret for signing tokens (use a long random string in production)
JWT_SECRET=replace_this_with_a_strong_secret

# Server port
PORT=5000
SHUTDOWN_TIMEOUT_MS=10000

# Frontend/CORS
FRONTEND_BASE_URL=http://localhost/serviio-project/frontend
CORS_ORIGIN=*
CORS_CREDENTIALS=false

# API rate limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20
SERVIIO_DEBUG_LOGS=false
SERVIIO_SOCKET_DEBUG=false
LOGIN_MAX_FAILED_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15

# Password reset
PASSWORD_RESET_EXPIRY_MINUTES=15
PASSWORD_RESET_MAX_ATTEMPTS=5

# Registration OTP verification. Defaults to required in production and optional
# in local development. Requires SMTP or SMS delivery when enabled for launch.
REGISTRATION_VERIFICATION_REQUIRED=false
REGISTRATION_VERIFICATION_EXPIRY_MINUTES=15
REGISTRATION_VERIFICATION_MAX_ATTEMPTS=5

# Optional SMTP. If omitted in development, forgot-password returns the reset
# link and OTP in the JSON response for local testing only.
APP_NAME=SERVIIO
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=SERVIIO <no-reply@serviio.local>

# SMS OTP delivery. Generic HTTP provider sends a JSON body by default:
# { "to": "8801...", "message": "...", "sender_id": "SERVIIO" }.
SMS_PROVIDER_URL=
SMS_PROVIDER_API_KEY=
SMS_PROVIDER_AUTH_HEADER=Authorization
SMS_PROVIDER_AUTH_SCHEME=Bearer
SMS_PROVIDER_RECIPIENT_FIELD=to
SMS_PROVIDER_MESSAGE_FIELD=message
SMS_PROVIDER_SENDER_FIELD=sender_id
SMS_PROVIDER_TIMEOUT_MS=10000
SMS_SENDER_ID=SERVIIO
SMS_MOCK_ENABLED=false

# KYC uploads / verification
KYC_MAX_FILE_MB=5
NID_VERIFICATION_MODE=disabled
NID_VERIFICATION_URL=
NID_VERIFICATION_API_KEY=
NID_VERIFICATION_AUTH_HEADER=Authorization
NID_VERIFICATION_AUTH_SCHEME=Bearer
NID_VERIFICATION_TIMEOUT_MS=10000
NID_VERIFICATION_MOCK_ENABLED=false
NID_VERIFICATION_TRUTHY_FIELDS=verified,matched,is_verified,is_matched,success
NID_VERIFICATION_STATUS_FIELDS=status,verification_status,result,match_status,data.status
NID_VERIFICATION_MATCH_VALUES=MATCHED,VERIFIED,VALID,VALIDATED,APPROVED,SUCCESS,FOUND
NID_VERIFICATION_MISMATCH_VALUES=MISMATCHED,REJECTED,INVALID,FAILED,NOT_FOUND,NO_MATCH
NID_VERIFICATION_REFERENCE_FIELDS=reference,request_id,id,transaction_id,trace_id,data.reference,data.id
POLICE_VERIFICATION_MODE=disabled
POLICE_VERIFICATION_URL=
POLICE_VERIFICATION_API_KEY=
POLICE_VERIFICATION_AUTH_HEADER=Authorization
POLICE_VERIFICATION_AUTH_SCHEME=Bearer
POLICE_VERIFICATION_TIMEOUT_MS=10000
POLICE_VERIFICATION_MOCK_ENABLED=false
POLICE_VERIFICATION_TRUTHY_FIELDS=verified,matched,is_verified,is_matched,success
POLICE_VERIFICATION_STATUS_FIELDS=status,verification_status,result,match_status,data.status
POLICE_VERIFICATION_MATCH_VALUES=MATCHED,VERIFIED,VALID,VALIDATED,APPROVED,SUCCESS,FOUND
POLICE_VERIFICATION_MISMATCH_VALUES=MISMATCHED,REJECTED,INVALID,FAILED,NOT_FOUND,NO_MATCH
POLICE_VERIFICATION_REFERENCE_FIELDS=reference,request_id,id,transaction_id,trace_id,data.reference,data.id
SKILL_VERIFICATION_MODE=disabled
SKILL_VERIFICATION_URL=
SKILL_VERIFICATION_API_KEY=
SKILL_VERIFICATION_AUTH_HEADER=Authorization
SKILL_VERIFICATION_AUTH_SCHEME=Bearer
SKILL_VERIFICATION_TIMEOUT_MS=10000
SKILL_VERIFICATION_MOCK_ENABLED=false
SKILL_VERIFICATION_TRUTHY_FIELDS=verified,matched,is_verified,is_matched,success
SKILL_VERIFICATION_STATUS_FIELDS=status,verification_status,result,match_status,data.status
SKILL_VERIFICATION_MATCH_VALUES=MATCHED,VERIFIED,VALID,VALIDATED,APPROVED,SUCCESS,FOUND
SKILL_VERIFICATION_MISMATCH_VALUES=MISMATCHED,REJECTED,INVALID,FAILED,NOT_FOUND,NO_MATCH
SKILL_VERIFICATION_REFERENCE_FIELDS=reference,request_id,id,transaction_id,trace_id,data.reference,data.id

# Payment/wallet. PLATFORM_COMMISSION_RATE is a decimal rate: 0.10 means 10%.
# It must be >= 0 and < 1.
PLATFORM_COMMISSION_RATE=0.10
PAYMENT_MODE=mock
MOCK_PAYMENTS_ENABLED=true
PAYMENT_GATEWAY_TIMEOUT_MS=15000
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
SSLCOMMERZ_VALIDATION_URL=https://sandbox.sslcommerz.com/validator/api/validationserverAPI.php
BKASH_BASE_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=
NAGAD_MERCHANT_ID=
NAGAD_MERCHANT_PRIVATE_KEY=
NAGAD_VERIFY_URL=
NAGAD_API_KEY=

# Live launch readiness probes. These are optional locally. Strict mode rejects
# skipped checks plus mock payment/KYC modes, so set real provider modes first.
LIVE_READINESS_STRICT=false
LIVE_READINESS_SMS_TO=
LIVE_READINESS_SMS_MESSAGE=
LIVE_READINESS_PAYMENT_AMOUNT=100
LIVE_READINESS_SSLCOMMERZ_VAL_ID=
LIVE_READINESS_BKASH_PAYMENT_ID=
LIVE_READINESS_NAGAD_PAYMENT_REF=
LIVE_READINESS_NID_NUMBER=
LIVE_READINESS_NID_FULL_NAME=
LIVE_READINESS_NID_DOB=
LIVE_READINESS_NID_PHONE=
LIVE_READINESS_DOCUMENT_FULL_NAME=
LIVE_READINESS_DOCUMENT_PHONE=
LIVE_READINESS_POLICE_DOCUMENT_NUMBER=
LIVE_READINESS_SKILL_DOCUMENT_NUMBER=

# Optional PowerShell E2E script target. Defaults are local/mock.
SERVIIO_E2E_BASE_URL=http://localhost:5000
SERVIIO_E2E_PAYMENT_METHOD=mock
SERVIIO_E2E_GATEWAY_REFERENCE=
