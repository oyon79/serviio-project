# Copy this file to .env and fill in real credentials
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=serviio_db

# JWT secret for signing tokens (use a long random string in production)
JWT_SECRET=replace_this_with_a_strong_secret

# Server port
PORT=5000

# Frontend/CORS
FRONTEND_BASE_URL=http://localhost/serviio-project/frontend
CORS_ORIGIN=*
CORS_CREDENTIALS=false

# API rate limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Password reset
PASSWORD_RESET_EXPIRY_MINUTES=15
PASSWORD_RESET_MAX_ATTEMPTS=5

# Optional SMTP. If omitted in development, forgot-password returns the reset
# link and OTP in the JSON response for local testing only.
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=SERVIIO <no-reply@serviio.local>

# Payment/wallet
PLATFORM_COMMISSION_RATE=0.10
